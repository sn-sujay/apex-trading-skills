# =============================================================================
# APEX Trading System - Environment Variables
# =============================================================================
# Copy this file to ~/.apex/.env or ~/.hermes/.env
# Fill in your credentials (leave blank if not needed)
# =============================================================================

# =============================================================================
# REQUIRED - For Live Trading
# =============================================================================

# Dhan API Credentials
# Get from: https://dhan.co/api-doc/
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# =============================================================================
# REQUIRED - For State Storage
# =============================================================================

# Local state file location (default: ~/.apex/state.json)
# APEX_STATE_PATH=~/.apex/state.json

# =============================================================================
# OPTIONAL - Telegram Alerts
# =============================================================================

# Telegram Bot Token
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID
# Your personal chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=

# =============================================================================
# OPTIONAL - Cloud State Sync (Upstash Redis)
# =============================================================================

# Upstash Redis URL (for multi-device state sync)
# Get from: https://upstash.com
UPSTASH_REDIS_REST_URL=

# Upstash Redis Token
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# OPTIONAL - Trading Configuration
# =============================================================================

# Auto-execute validated trades (true/false)
APEX_AUTO_EXECUTE=false

# Maximum position size per trade (₹)
APEX_MAX_POSITION_SIZE=50000

# Maximum loss per day (₹)
APEX_MAX_LOSS_PER_DAY=10000

# Maximum trades per day
APEX_MAX_TRADES_PER_DAY=10

# =============================================================================
# OPTIONAL - Strategy Weights
# =============================================================================

# Strategy allocation weights (must sum to 1.0)
# STRATEGY_BREAKOUT=0.30
# STRATEGY_MOMENTUM=0.25
# STRATEGY_MEAN_REVERSION=0.20
# STRATEGY_MTF_EMA=0.15
# STRATEGY_OPTION_SPREAD=0.10

# =============================================================================
# OPTIONAL - Debug & Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
APEX_LOG_LEVEL=INFO

# Debug mode (true/false)
APEX_DEBUG=false

# Log directory
# APEX_LOG_PATH=~/.hermes/logs/

# =============================================================================
# OPTIONAL - API Rate Limits
# =============================================================================

# Dhan API rate limits (these are defaults, don't change unless needed)
# DHAN_MAX_ORDERS_PER_SECOND=5
# DHAN_MAX_ORDERS_PER_MINUTE=100
# DHAN_MAX_MODIFICATIONS_PER_SECOND=2

# =============================================================================
# OPTIONAL - Market Hours (IST)
# =============================================================================

# Trading hours (default: 9:15 AM - 3:30 PM IST)
# APEX_MARKET_OPEN=09:15
# APEX_MARKET_CLOSE=15:30

# =============================================================================
# DO NOT EDIT BELOW THIS LINE (Internal APEX configuration)
# =============================================================================

# APEX Version (do not modify)
APEX_VERSION=2.0